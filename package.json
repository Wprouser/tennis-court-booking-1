{
  "name": "tennis-court-booking",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"cross-env PORT=3001 node --watch server/index.js\"",
    "build": "vite build",
    "start": "node server/index.js",
    "auth:migrate": "better-auth migrate --yes",
    "db:migrate": "node server/migrate.js",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1"
  }
}
